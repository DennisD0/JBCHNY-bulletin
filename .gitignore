# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
server-*.log

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# Windows-only parts of the OMR engine (not needed in the Docker image)
/tools/audiveris/audiveris.msi
/tools/audiveris/Audiveris/Audiveris.exe
/tools/audiveris/Audiveris/runtime
/tools/audiveris/Audiveris/app/*-windows-x86_64.jar
# Tunnel binary (downloaded locally, not needed in repo)
/tools/cloudflared.exe

# OMR working files (uploads, job output)
/omr-data
/tmp

# local demo server and tunnel logs
/server.out.log
/server.err.log
/tunnel.out.log
/tunnel.err.log
/.next-*.log
/data/*.bak
/data/bible_verse_cache.json
/data/bible_*.json

# typescript
*.tsbuildinfo
next-env.d.ts
