  "memoryVerses": [
    {
      "label": "Semana pasada",
      "date": "6/21",
      "reference": "2 Corintios 4:17-18",
      "theme": "Esperanza",
      "text": "Porque esta leve tribulación momentánea produce en nosotros un cada vez más excelente y eterno peso de gloria; no mirando nosotros las cosas que se ven, sino las que no se ven; pues las cosas que se ven son temporales, pero las que no se ven son eternas."
    },
    {
      "label": "Esta semana",
      "date": "6/28",
      "reference": "1 Pedro 1:3-4",
      "theme": "Esperanza",
      "text": "Bendito el Dios y Padre de nuestro Señor Jesucristo, que según su grande misericordia nos hizo renacer para una esperanza viva, por la resurrección de Jesucristo de los muertos, para una herencia incorruptible, incontaminada e inmarcesible, reservada en los cielos para vosotros,"
    },
    {
      "label": "Próxima semana",
      "date": "7/5",
      "reference": "1 Pedro 3:15-16",
      "theme": "Esperanza",
      "text": "sino santificad a Dios el Señor en vuestros corazones, y estad siempre preparados para presentar defensa con mansedumbre y reverencia ante todo el que os demande razón de la esperanza que hay en vosotros; teniendo buena conciencia, para que en lo que murmuran de vosotros como de malhechores, sean avergonzados los que calumnian vuestra buena conducta en Cristo."
    }
  ],
