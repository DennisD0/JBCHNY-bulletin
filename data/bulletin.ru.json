  "memoryVerses": [
    {
      "label": "На прошлой неделе",
      "date": "6/21",
      "reference": "2 Corinthians 4:17-18",
      "theme": "Надеяться",
      "text": "Ибо кратковременное легкое страдание наше производит в безмерном преизбытке вечную славу, когда мы смотрим не на видимое, но на невидимое: ибо видимое временно, а невидимое вечно."
    },
    {
      "label": "На этой неделе",
      "date": "6/28",
      "reference": "1 Peter 1:3-4",
      "theme": "Надеяться",
      "text": "Благословен Бог и Отец Господа нашего Иисуса Христа, по великой Своей милости возродивший нас воскресением Иисуса Христа из мертвых к упованию живому, к наследству нетленному, чистому, неувядаемому, хранящемуся на небесах для вас,"
    },
    {
      "label": "На следующей неделе",
      "date": "7/5",
      "reference": "1 Peter 3:15-16",
      "theme": "Надеяться",
      "text": "Господа Бога святите в сердцах ваших; будьте всегда готовы всякому, требующему у вас отчета в вашем уповании, дать ответ с кротостью и благоговением. Имейте добрую совесть, дабы тем, за что злословят вас, как злодеев, были постыжены порицающие ваше доброе житие во Христе."
    }
  ],
